# ------------------ Extract Data from Word -------------------
# =============================================================

def extract_data(file_path):
    CATEGORY_PATTERN = r'^(~|[A-M])\.\s*(.*)'
    NUMERIC_PATTERN = r'^(\d+[a-zA-Z]?)\.\s*(.*)'
    ROMAN_PATTERN = r'^([IVXLCDM]+)\.\s*(.*)'
    BULLET_PATTERN = r'^[\u25A1\u25CB•▪○]+\s*'
    HELP_TEXT_MARKERS = [ "Se", "Uma", "Duas","Mais", "A", "*A", "All-in-all-out", "Um","Enterrado", "Os", "Por", 
    "Oum", "Ou", "Tem","Telas", "Propriedade", "Profissional", "Algumas","Compartimento", "Esta", "Isto", 
    "Veículos","Separação", "Visitantes"]
    HELP_TEXT_COLOR = (118, 113, 113)
    REDIRECT_MSG_PATTERN = r'(Se.*?v[aá] para a pergunta [IVXLCDM0-9]+[a-zA-Z]?)'

    doc = docx.Document(file_path)

    blocks = []
    for element in doc.element.body:
        if element.tag.endswith('}p'):
            blocks.append(docx.text.paragraph.Paragraph(element, doc))
        elif element.tag.endswith('}tbl'):
            blocks.append(docx.table.Table(element, doc))

    categories = []
    questions = []

    current_category = None
    current_question = None
    current_number = None
    current_answers = []
    current_help_text = ""
    current_redirect = ""

    def save_current_question():
        nonlocal current_question, current_number, current_answers
        nonlocal current_help_text, current_redirect, questions

        if current_question:
            questions.append({
                "question": current_question.strip(),
                "answers": current_answers,
                "redirect": current_redirect.strip(),
                "help_text": current_help_text.strip(),
                "number": current_number
            })

        current_question = None
        current_number = None
        current_answers = []
        current_help_text = ""
        current_redirect = ""

    def save_current_category():
        nonlocal current_category, questions, categories

        if current_category is not None:
            categories.append({
                "category_name": current_category,
                "questions": questions
            })

        questions = []

    for block in blocks:
        if isinstance(block, docx.text.paragraph.Paragraph):
            text = block.text.strip().replace("(obrigatório)", "").strip()

            if not text:
                continue

            font_size = None
            if block.runs and block.runs[0].font.size:
                font_size = block.runs[0].font.size.pt

            category_match = re.match(CATEGORY_PATTERN, text)
            question_match = re.match(NUMERIC_PATTERN, text) or re.match(ROMAN_PATTERN, text)

            if category_match and font_size and font_size >= 16 and "glossario" not in text.lower():
                save_current_question()
                save_current_category()
                current_category = category_match.group(2).strip()
                continue

            if question_match and current_category is not None:
                save_current_question()
                current_number = question_match.group(1).strip()
                current_question = question_match.group(2).strip()
                continue

            if is_instruction_text(text):
                continue

            if block.style.name.startswith("List") or re.match(BULLET_PATTERN, text):
                answer_text = re.sub(BULLET_PATTERN, "", text).strip()

                if is_instruction_text(answer_text):
                    continue

                if answer_text:
                    current_answers.append(answer_text)

                continue

            if re.search(REDIRECT_MSG_PATTERN, text):
                current_redirect += " " + text
                continue

            for run in block.runs:
                if run.font.color and run.font.color.rgb:
                    color = (
                        run.font.color.rgb[0],
                        run.font.color.rgb[1],
                        run.font.color.rgb[2]
                    )
            
                    if (
                        color == HELP_TEXT_COLOR
                        or any(marker in run.text for marker in HELP_TEXT_MARKERS)
                    ):
                        current_help_text += " " + text
                        break

        elif isinstance(block, Table) and current_question:
            headers = []
            statements = []

            for i, row in enumerate(block.rows):
                cells = [cell.text.strip() for cell in row.cells]

                if i == 0:
                    headers = [
                        c for c in cells
                        if c and not is_instruction_text(c)
                    ]
                else:
                    if any(cells):
                        statements.append(" - ".join(cells).strip())

            if headers and statements:
                questions.append({
                    "question": current_question.strip(),
                    "answers": headers,
                    "statements": statements,
                    "redirect": current_redirect.strip(),
                    "help_text": current_help_text.strip(),
                    "number": current_number
                })

                current_question = None
                current_number = None
                current_answers = []
                current_help_text = ""
                current_redirect = ""

    save_current_question()

    if current_category is not None and questions:
        categories.append({
            "category_name": current_category,
            "questions": questions
        })

    return categories


