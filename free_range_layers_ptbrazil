def fill_question_identifier(driver, question_number):
    """
    Fill 'Question identifier (all languages)' with the Word question number.
    This is only called for checkbox instruction questions such as 7b, 8b, 10b.

    Uses JavaScript because this field can be required/managed by Drupal and
    sometimes Selenium clear()/send_keys() fails even when the element exists.
    """
    if not question_number:
        print("⚠️ No question number available for identifier.")
        return

    try:
        # Preferred selector from the HTML:
        # <input id="edit-identifier-0-value" name="identifier[0][value]" ...>
        field = WebDriverWait(driver, 5).until(
            EC.presence_of_element_located((By.ID, "edit-identifier-0-value"))
        )

        driver.execute_script(
            "arguments[0].scrollIntoView({block:'center'});",
            field
        )

        value = str(question_number)

        # JS is more reliable than field.clear()/send_keys() for Drupal fields.
        driver.execute_script(
            """
            const el = arguments[0];
            const value = arguments[1];
            el.focus();
            el.value = value;
            el.setAttribute('value', value);
            el.dispatchEvent(new Event('input', {bubbles: true}));
            el.dispatchEvent(new Event('change', {bubbles: true}));
            el.blur();
            """,
            field,
            value
        )

        print(f"🔢 Set question identifier: {question_number}")

    except Exception as e:
        print(f"⚠️ Could not set question identifier {question_number}: {e}")

