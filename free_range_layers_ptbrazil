# ------------------ Process Items ----------------------------
# =============================================================

def process_items(driver, categories):
    print("🔧 Starting to process items...")

    all_category_names = [cat["category_name"] for cat in categories]
    all_questions = [q for cat in categories for q in cat["questions"]]

    item_index = 0
    question_index = 0
    category_index = 0

    total_items = len(all_category_names) + len(all_questions)

    while item_index < total_items:
        try:
            print(f"\n🔍 Processing item {item_index + 1}...")

            translate_link = WebDriverWait(driver, 10).until(
                EC.element_to_be_clickable(
                    (
                        By.XPATH,
                        f"(//tr[td]//a[text()='Translate'])[{item_index + 1}]"
                    )
                )
            )

            try:
                translate_link.click()
            except StaleElementReferenceException:
                translate_link = WebDriverWait(driver, 5).until(
                    EC.element_to_be_clickable(
                        (
                            By.XPATH,
                            f"(//tr[td]//a[text()='Translate'])[{item_index + 1}]"
                        )
                    )
                )
                translate_link.click()

            row = WebDriverWait(driver, 10).until(
                EC.presence_of_element_located(
                    (
                        By.XPATH,
                        "//tr[td//text()[contains(., 'Portuguese')]]"
                    )
                )
            )

            edit_links = row.find_elements(By.XPATH, ".//a[contains(@href, '/edit')]")

            if edit_links:
                edit_links[0].click()
                print("✏️ Clicked 'Edit'")
            else:
                add_links = row.find_elements(By.XPATH, ".//a[contains(@href, '/add')]")

                if add_links:
                    add_links[0].click()
                    print("➕ Clicked 'Add'")
                else:
                    print("⚠️ No edit or add link found, skipping item")
                    item_index += 1
                    driver.get(questionnaire_url)
                    continue

            WebDriverWait(driver, 10).until(
                EC.presence_of_element_located((By.TAG_NAME, "form"))
            )

            labels = driver.find_elements(By.XPATH, "//label")

            # Each edit/add page corresponds to ONE item only: either one category
            # or one question. After filling that item, break out of the label loop
            # so the script does not accidentally consume the next Word question
            # on the same page before clicking Save.
            item_filled = False

            for label in labels:
                label_text = label.text.strip()
                input_id = label.get_attribute("for")

                if not input_id:
                    continue

                if "Category name" in label_text and category_index < len(all_category_names):
                    field = driver.find_element(By.ID, input_id)
                    set_text_input_value(
                        driver,
                        field,
                        all_category_names[category_index],
                        label="category"
                    )

                    print(f"🏷️ Set category: {all_category_names[category_index]}")
                    category_index += 1
                    item_filled = True
                    break

                label_text_lower = label_text.lower()

                # IMPORTANT: Do not treat "Question identifier (all languages)" as the
                # translatable Question field. It is a separate field.
                is_main_question_field = (
                    "question" in label_text_lower
                    and "identifier" not in label_text_lower
                    and "sequence" not in label_text_lower
                )

                if is_main_question_field and question_index < len(all_questions):
                    current = all_questions[question_index]
                    question_text = clean_question_text(current["question"])

                    field = driver.find_element(By.ID, input_id)

                    # Only checkbox instruction questions like 7b, 8b, 10b need the
                    # Question identifier field filled. For normal questions, do not touch it.
                    if is_checkbox_instruction_question(question_text):
                        fill_question_identifier(driver, current.get("number"))
                        set_text_input_value(
                            driver,
                            field,
                            question_text,
                            label=f"checkbox question text {current.get('number')}"
                        )
                        print(
                            f"☑️ Checkbox instruction detected for question {current['number']}. "
                            "Filled translated question text and identifier."
                        )
                    else:
                        set_text_input_value(
                            driver,
                            field,
                            question_text,
                            label="question text"
                        )
                        print(f"❓ Set question: {question_text}")

                    if current.get("statements"):
                        print("📐 Matrix question detected.")
                        fill_matrix_question(driver, current)
                    else:
                        print("🅰️ Standard question detected. Filling answers...")

                        answers = [
                            a.strip()
                            for a in current.get("answers", [])
                            if not is_instruction_text(a.strip())
                        ]

                        print("Answers extracted:")
                        for idx, ans in enumerate(answers):
                            print(f"  {idx}: {ans}")

                        answer_fields = driver.find_elements(
                            By.CSS_SELECTOR,
                            'input[id^="edit-field-potential-answers-"][id$="-value"]'
                        )

                        available_count = len(answer_fields)

                        if len(answers) > available_count:
                            print(
                                f"⚠️ Word contains {len(answers)} answers "
                                f"but form only contains {available_count} fields."
                            )
                            print("⚠️ Missing answers:")
                            for missing in answers[available_count:]:
                                print(f"   - {missing}")

                        for i, ans in enumerate(answers[:available_count]):
                            try:
                                ans_field = WebDriverWait(driver, 10).until(
                                    EC.presence_of_element_located(
                                        (
                                            By.ID,
                                            f"edit-field-potential-answers-{i}-value"
                                        )
                                    )
                                )

                                driver.execute_script(
                                    "arguments[0].scrollIntoView({block:'center'});",
                                    ans_field
                                )

                                set_text_input_value(
                                    driver,
                                    ans_field,
                                    ans,
                                    label=f"answer {i + 1}"
                                )

                                print(f"✅ Answer {i + 1}: {ans}")

                            except Exception as e:
                                print(
                                    f"⚠️ Could not set answer {i + 1}: "
                                    f"{ans} -> {e}"
                                )

                    if current.get("help_text"):
                        fill_ckeditor5_field(
                            driver,
                            "edit-help-0-value",
                            current["help_text"],
                            label="Help text"
                        )
                    else:
                        fill_ckeditor5_field(
                            driver,
                            "edit-help-0-value",
                            "",
                            label="Help text cleared"
                        )

                    if current.get("redirect"):
                        fill_ckeditor5_field(
                            driver,
                            "edit-conditional-help-0-value",
                            current["redirect"],
                            label="Redirect"
                        )
                    else:
                        fill_ckeditor5_field(
                            driver,
                            "edit-conditional-help-0-value",
                            "",
                            label="Redirect cleared"
                        )

                    question_index += 1
                    item_filled = True
                    break

            save_button = WebDriverWait(driver, 20).until(
                EC.element_to_be_clickable((By.ID, "edit-submit"))
            )

            driver.execute_script(
                "arguments[0].scrollIntoView({block:'center'});",
                save_button
            )

            time.sleep(1)
            driver.execute_script("arguments[0].click();", save_button)

            print("💾 Clicked Save")

            item_index += 1
            time.sleep(2)
            driver.get(questionnaire_url)

        except Exception as e:
            print(f"❌ Error at item {item_index + 1}: {e}")
            item_index += 1

            try:
                driver.get(questionnaire_url)
                time.sleep(2)
            except Exception:
                pass

            continue


