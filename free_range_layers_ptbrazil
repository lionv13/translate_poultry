def is_instruction_text(text):
    if not text:
        return True

    cleaned = text.strip()

    skip_texts = {
        "Selecione uma opção",
        "Selecione uma opção.",
        "Marque todas as opções aplicáveis",
        "Marque todas as opções aplicáveis.",
        "Mark all applicable options",
        "Mark all applicable options.",
        "Select one option",
        "Select one option.",
        "Check any that apply",
        "Check any that apply."
    }

    return cleaned in skip_texts


def is_checkbox_instruction_question(question_text):
    if not question_text:
        return False

    cleaned = question_text.strip().lower()

    return cleaned in {
        "marque todas as opções aplicáveis",
        "marque todas as opções aplicáveis.",
        "check any that apply",
        "check any that apply."
    }


def clean_question_text(question_text):
    return re.sub(
        r'^(\d+[a-zA-Z]?|[IVXLCDM]+)\.\s*',
        '',
        question_text or ''
    ).strip()


def set_text_input_value(driver, field, value, label="field"):
    """Set a normal text input reliably, even when Selenium clear()/send_keys() fails."""
    value = str(value or "")
    try:
        driver.execute_script("arguments[0].scrollIntoView({block:'center'});", field)
        driver.execute_script(
            """
            const el = arguments[0];
            const value = arguments[1];
            el.focus();
            el.value = value;
            el.setAttribute('value', value);
            el.dispatchEvent(new Event('input', {bubbles: true}));
            el.dispatchEvent(new Event('change', {bubbles: true}));
            el.blur();
            """,
            field,
            value
        )
        print(f"✅ Set {label}: {value}")
        return True
    except Exception as e:
        print(f"⚠️ Could not set {label}: {e}")
        return False


